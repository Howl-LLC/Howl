{
  "name": "howl",
  "private": true,
  "version": "1.0.5",
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "main.js",
  "author": "Howl <support@howlpro.com>",
  "description": "Futuristic real-time messaging app",
  "scripts": {
    "dev": "npx vite",
    "dev:frontend": "npx vite",
    "dev:backend": "npm run dev --prefix backend",
    "dev:admin": "npm run dev --prefix admin",
    "build:admin": "npm run build --prefix admin",
    "dev:electron": "electron .",
    "build:frontend": "vite build",
    "optimize:landing": "node scripts/optimize-landing-images.mjs",
    "check:schema-compat": "npx tsx scripts/check-schema-compat.ts",
    "check:licenses": "node scripts/check-licenses.mjs",
    "build:electron": "node scripts/build-release.mjs",
    "start": "npm run dev",
    "predist": "node scripts/build-release.mjs",
    "predist:mac": "node scripts/build-release.mjs",
    "predist:linux": "node scripts/build-release.mjs",
    "predist:all": "node scripts/build-release.mjs",
    "dist": "node scripts/set-build-date.js --win",
    "dist:mac": "node scripts/set-build-date.js --mac",
    "dist:linux": "node scripts/set-build-date.js --linux",
    "dist:all": "node scripts/set-build-date.js --win --mac --linux",
    "ngrok": "ngrok http 3000",
    "lint": "eslint components/ contexts/ hooks/ services/ shared/ utils/ __tests__/ electron/streamdeck/ App.tsx config.ts index.tsx types.ts src/",
    "lint:fix": "eslint components/ contexts/ hooks/ services/ shared/ utils/ __tests__/ electron/streamdeck/ App.tsx config.ts index.tsx types.ts src/ --fix",
    "audit:security": "npm audit --production --audit-level=high",
    "audit:all": "npm run audit:security && npm run audit:security --prefix backend",
    "test:mobile": "playwright test",
    "test:mobile:headed": "playwright test --headed",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:streamdeck": "vitest run __tests__/streamdeck",
    "prepare": "husky",
    "postinstall": "node scripts/copy-mediapipe-assets.mjs && node scripts/fetch-fonts.mjs",
    "predev": "node scripts/copy-mediapipe-assets.mjs && node scripts/fetch-fonts.mjs",
    "prebuild:frontend": "node scripts/copy-mediapipe-assets.mjs && node scripts/fetch-fonts.mjs"
  },
  "dependencies": {
    "@floating-ui/react": "0.27.19",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/opendyslexic": "^5.2.5",
    "@fontsource/plus-jakarta-sans": "^5.2.8",
    "@hpke/hybridkem-x-wing": "0.6.1",
    "@jitsi/rnnoise-wasm": "^0.2.1",
    "@lexical/clipboard": "^0.42.0",
    "@lexical/history": "^0.42.0",
    "@lexical/react": "^0.42.0",
    "@lexical/selection": "^0.42.0",
    "@lexical/utils": "^0.42.0",
    "@livekit/track-processors": "^0.7.2",
    "@mediapipe/tasks-vision": "^0.10.34",
    "@sentry/electron": "^7.11.0",
    "@sentry/react": "^10.40.0",
    "@simplewebauthn/browser": "^13.2.2",
    "clsx": "^2.1.1",
    "cobe": "^0.6.5",
    "deepfilternet3-noise-filter": "^1.2.1",
    "dompurify": "^3.3.3",
    "electron-updater": "^6.8.3",
    "hash-wasm": "^4.12.0",
    "highlight.js": "^11.11.1",
    "i18next": "^25.8.13",
    "idb": "^8.0.3",
    "lexical": "^0.42.0",
    "livekit-client": "^2.17.2",
    "lucide-react": "^0.574.0",
    "minisearch": "^7.2.0",
    "motion": "^12.35.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.4",
    "react-router-dom": "^7.13.1",
    "react-virtuoso": "^4.18.3",
    "socket.io-client": "^4.8.1",
    "tailwind-merge": "^3.5.0",
    "ts-mls": "1.6.2",
    "turndown": "^7.2.2",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "uiohook-napi": "1.5.4",
    "ws": "^8.20.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron/fuses": "^2.1.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.0.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^5.1.4",
    "archiver": "^7.0.1",
    "autoprefixer": "^10.4.24",
    "electron": "^40.4.1",
    "electron-builder": "^26.8.0",
    "esbuild": "^0.27.0",
    "eslint": "^10.0.2",
    "eslint-plugin-security": "^4.0.0",
    "fake-indexeddb": "^6.0.0",
    "http-proxy": "^1.18.1",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.6",
    "rcedit": "^5.0.2",
    "shadcn": "^4.0.0",
    "sharp": "^0.35.2",
    "tailwindcss": "^4.2.0",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.2",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-sri3": "^1.3.0",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "serialize-javascript": ">=7.0.3"
  },
  "build": {
    "beforeBuild": "./build/beforeBuild.cjs",
    "afterPack": "./build/afterPack.cjs",
    "protocols": [
      {
        "name": "Howl",
        "schemes": [
          "howl"
        ]
      }
    ],
    "appId": "com.howl.app",
    "productName": "Howl",
    "copyright": "Copyright © 2026 Howl",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "overlayPreload.js",
      "gameScanner.js",
      "spotifyDetector.js",
      "package.json",
      "public/howl-logo.png",
      "public/howl-logo.ico",
      "public/game-database.json",
      "update-screen.html",
      "update-screen.js",
      "repair-screen.html",
      "repair-screen.js",
      "release-config.json",
      "release-config.example.json",
      "electron/**/*",
      "node_modules/uiohook-napi/**/*"
    ],
    "asarUnpack": [
      "preload.js",
      "overlayPreload.js",
      "public/howl-logo.png",
      "public/howl-logo.ico",
      "node_modules/@sentry/electron/**/*"
    ],
    "icon": "public/howl-logo.png",
    "win": {
      "icon": "public/howl-logo.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "artifactName": "Howl-Setup.${ext}",
      "verifyUpdateCodeSignature": true,
      "signtoolOptions": {
        "sign": "./build/sign-windows.cjs",
        "signingHashAlgorithms": [
          "sha256"
        ],
        "publisherName": [
          "Howl LLC"
        ]
      }
    },
    "mac": {
      "icon": "public/howl-logo.png",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "artifactName": "Howl-${arch}.${ext}",
      "category": "public.app-category.social-networking",
      "hardenedRuntime": true,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "artifactName": "Howl-${arch}.${ext}",
      "category": "Network;InstantMessaging",
      "extraResources": [
        {
          "from": "build/apparmor-howl",
          "to": "apparmor-howl"
        }
      ]
    },
    "deb": {
      "afterInstall": "build/deb-postinstall.sh",
      "afterRemove": "build/deb-postremove.sh"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Howl",
      "uninstallDisplayName": "Howl",
      "runAfterFinish": true,
      "include": "build/nsis-hooks.nsh",
      "guid": "25539d2d-12ba-5691-9181-135b33128d2a"
    }
  }
}
