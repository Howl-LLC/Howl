# Backend .env — copy to backend/.env and fill in. Used only when running the backend (from backend/).
# Do NOT put VITE_* here; those go in the project root .env.

# Must be 5000 so the frontend (port 3000) can reach the API. If you use a different port,
# set VITE_BACKEND_PORT in the project root .env to match.
PORT=5000
NODE_ENV=development

# Logging level (pino). Options: fatal, error, warn, info, debug, trace, silent.
# Defaults to 'debug' in dev, 'info' in production.
# In production, JSON logs are output to stdout — pipe to CloudWatch/Datadog/ELK.
LOG_LEVEL=

# JWT secret - use a long random string in production (required for login/auth)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Database - REQUIRED for production (login, DMs, servers, etc.).
# Optional only for minimal local runs without auth (e.g. health check only).
# Set to your PostgreSQL connection string (never commit real credentials).
# Production: add ?sslmode=require and use connection_limit, e.g.:
#   DATABASE_URL="postgresql://user:pass@host:5432/howl?sslmode=require&connection_limit=10&pool_timeout=30"
DATABASE_URL="postgresql://user:password@localhost:5432/howl?schema=public"

# Connection pool size. Default 50. Increase if running many BullMQ workers.
# DB_POOL_MAX=50
# DB_POOL_MIN=2

# AWS Secrets Manager — if set, DATABASE_URL is fetched from this secret at startup.
# Preferred over hardcoding DB credentials in env vars.
# RDS_SECRET_ARN=arn:aws:secretsmanager:us-east-1:ACCOUNT_ID:secret:howl/rds-xxxxx

# Production only: comma-separated frontend origins for CORS (e.g. https://yourapp.com).
# Leave unset in dev (allows *). Set on the host when you deploy the frontend.
# FRONTEND_ORIGIN=https://yourapp.com

# Stripe - required for billing / Howl Pro subscriptions.
# Get these from https://dashboard.stripe.com/test/apikeys and Webhooks section.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_ESSENTIAL_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_BOOST_PRICE_ID=price_...    # Monthly $3.99/boost price ID

# AWS region (used as fallback for S3_REGION)
AWS_REGION=us-east-1

# Resend API key — required for transactional emails (verification, password reset, etc.).
# Get yours at https://resend.com/api-keys
RESEND_API_KEY=

# Email sender (Resend). Defaults to "Howl <noreply@example.com>" if unset.
EMAIL_FROM=Howl <noreply@example.com>

# File storage (AWS S3) - leave S3_BUCKET empty to use local disk (dev default).
# When set, uploads go to S3 and GET /api/uploads/:filename redirects to a presigned URL.
# On EC2 with an IAM instance role, ACCESS_KEY_ID/SECRET_ACCESS_KEY are optional.
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_KEY_PREFIX=uploads/
# S3-compatible endpoint (required for Cloudflare R2, optional for AWS S3).
# Example for R2: https://<account-id>.r2.cloudflarestorage.com
S3_ENDPOINT=

# CDN signed URL HMAC secret — REQUIRED in production when CDN_BASE_URL is set.
# Must match the HMAC_SIGNING_SECRET set on the cdn-signer Cloudflare Worker.
# Generate with: openssl rand -base64 48
# Minimum 32 characters enforced on prod startup.
CDN_SIGNING_SECRET=

# How long signed CDN URLs remain valid (seconds). Default 1800 (30 min).
# Balance: shorter = better leak protection; longer = less frequent re-issue.
# CDN_URL_TTL_SECONDS=1800

# Per-resource ACL on GET /api/uploads/:filename (channel/DM attachments).
# Leave unset/false until the frontend tokening (video + thread/forum) is live,
# then set true.
UPLOAD_ACL_ENABLED=false

# Cloudflare CDN purge — optional. When set, deleteUploadedFile()
# purges the CDN cache so deleted attachments don't linger on the edge.
# Get a scoped API token at https://dash.cloudflare.com/profile/api-tokens
# with the "Zone > Cache Purge" permission for the CDN zone only.
# CLOUDFLARE_ZONE_ID=
# CLOUDFLARE_API_TOKEN=

# CAPTCHA (Cloudflare Turnstile) - leave empty in dev to skip verification
TURNSTILE_SECRET_KEY=

# SSO - Google OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/sso/google/callback

# SSO - Apple Sign In
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# SSO - Steam OpenID
STEAM_API_KEY=

# Spotify Connected App (OAuth2 — NOT SSO, used for activity/profile features)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:5000/api/v1/connected-apps/spotify/callback
# Spotify polling interval in ms (default: 30000, min: 15000)
SPOTIFY_POLL_INTERVAL_MS=30000

# Klipy GIF API (optional) — get key at https://partner.klipy.com
# Leave empty to disable GIF search/trending.
# KLIPY_API_KEY=

# Admin panel — Cloudflare Access (Zero Trust) gates all admin routes.
# All admin routes require a valid Cf-Access-Jwt-Assertion header, signed by
# your CF Access team domain. Create the Access Application in the Zero Trust
# dashboard with path matchers /api/admin/* and /api/v1/admin/*, then record
# the AUD tag and team domain below.
#
# CF_ACCESS_TEAM_DOMAIN: your team's CF Access domain (no scheme).
#   Example: your-team.cloudflareaccess.com
# CF_ACCESS_AUD: the AUD tag shown on the Access Application settings page.
# CF_ACCESS_ENFORCE: when "true" (the production default), reject admin
#   requests missing a valid JWT. Leave "false" only for local testing where
#   the middleware logs warnings but passes through.
#
# In dev, if CF_ACCESS_TEAM_DOMAIN is unset the middleware is a no-op and
# logs a warning once at startup.
CF_ACCESS_TEAM_DOMAIN=
CF_ACCESS_AUD=
CF_ACCESS_ENFORCE=true

# Admin panel — separate JWT secret for admin tokens (REQUIRED in production).
# Must differ from JWT_SECRET to isolate admin/user token scopes.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ADMIN_JWT_SECRET=

# Admin panel — secret key that protects the Bull Board dashboard route.
# Set to a long random string; the admin must include it in the dashboard URL.
ADMIN_DASHBOARD_KEY=

# Admin panel — origin URL of the admin frontend (CORS and cookie scope).
# Example: https://admin.example.com
ADMIN_ORIGIN=http://localhost:3001

# MFA encryption (32-byte hex key for encrypting TOTP secrets at rest)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MFA_ENCRYPTION_KEY=

# Email HMAC key — REQUIRED in production. Keyed-hash for email lookup
# (login, register, password reset, SSO link, email change). Min 32 chars.
# Generate with: openssl rand -hex 32
EMAIL_HMAC_KEY=

# DM message encryption at rest (32-byte hex key for encrypting DM content in the database)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DM_ENCRYPTION_KEY=

# ALLOW_TEST_ESCROW_KEY — TEST-ONLY. NEVER set in production or staging.
# Gates the deterministic SHA-256 escrow fallback that getMasterKey() uses when
# SERVER_E2E_MASTER_KEY is absent under NODE_ENV=test. Without this flag, escrow
# fails closed (no silent constant-key escrow). See backend/src/services/e2eEscrow.ts.
# ALLOW_TEST_ESCROW_KEY=

# WebAuthn (passkeys — main user frontend)
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3000

# Admin WebAuthn — optional override. The admin panel runs at a separate
# origin (admin.example.com) from the main frontend, so its passkey config
# is derived from ADMIN_ORIGIN by default (origin + hostname). Set
# ADMIN_WEBAUTHN_RP_ID only if you want a parent-domain RP ID (e.g.
# "example.com" so one passkey works across subdomains).
ADMIN_WEBAUTHN_RP_ID=

# Redis — required for multi-instance Socket.IO and shared state.
# Leave empty for single-instance dev (in-memory fallback).
# For production: use AWS ElastiCache Redis or a standalone Redis instance.
REDIS_URL=

# LiveKit SFU (voice/video calls)
#
# ── Local dev ───────────────────────────────────────────────────────────
#
#   For local dev run LiveKit in --dev mode:
#     livekit-server --dev --keys "devkey: secret"
#   Then point the backend at it:
#     LIVEKIT_WS_URL=ws://localhost:7880
#
# ── Docker (alternative) ────────────────────────────────────────────────
#
#   docker run --rm -p 7880:7880 -p 7881:7881 -p 50000-50060:50000-50060/udp \
#     -e LIVEKIT_KEYS="devkey: secret" livekit/livekit-server
#
# ── Production (bare metal / VPS) ───────────────────────────────────────
#
#   In production, LiveKit runs on a bare-metal or VPS server behind a
#   stable domain with TLS. Set these once and they never change:
#
#     LIVEKIT_WS_URL=wss://livekit.example.com
#     LIVEKIT_API_KEY=<generated key>
#     LIVEKIT_API_SECRET=<generated secret>
#
#   Generate real credentials:  docker run --rm livekit/generate
#   See livekit.yaml.example in the repo root for full production config.
#
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_WS_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# Error tracking (Sentry) — leave empty in dev to disable.
# Get your DSN from https://sentry.io → Project Settings → Client Keys (DSN).
SENTRY_DSN=

# Web Push (VAPID) — required for push notifications.
# Generate keypair: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Allow null origin for Socket.IO (Electron desktop clients only).
# MUST be false or unset for web-only deployments.
# ALLOW_NULL_ORIGIN=false
