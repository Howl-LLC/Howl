model MessageReport {
  id                          String    @id @default(uuid())
  // reporterId nullable so reports survive reporter self-delete. The
  // moderator-audit trail must outlive the reporter (prevents a bad actor
  // from wiping evidence by deleting their account).
  reporterId                  String?
  messageType                 String // "dm" or "channel"
  messageId                   String
  channelId                   String?
  dmChannelId                 String?
  // Was non-null + Cascade. Now nullable + SetNull so a CSAM uploader cannot
  // erase evidence by self-deleting (18 USC §2258A(h) preservation). The
  // human-readable identity that *was* attached at report time lives in the
  // *Snapshot fields below — those survive the user delete and are what
  // moderators / NCMEC actually need.
  authorId                    String?
  // Identity snapshot taken when the report is created (auto-flag) or first
  // actioned. Frozen on insert; never updated after the User row is gone.
  authorUsernameSnapshot      String?
  authorDiscriminatorSnapshot String?
  authorEmailHashSnapshot     String? // hashEmail() — useful for cross-account linkage
  authorRegisteredAtSnapshot  DateTime?
  // Forensic capture. Two distinct evidentiary qualities live in these fields:
  //   - At auto-flag block: the IP/UA of the actual upload request — the IP
  //     that committed the offense. Gold standard.
  //   - At admin-action time for user-reported CSAM: best-effort lookup of
  //     the session that was active around the message timestamp (within
  //     the 90-day Session.rawIp retention window). Null if the window has
  //     expired by the time T&S confirms.
  // `evidenceSource` records which path populated these so an investigator
  // reading the report later doesn't conflate the two.
  uploaderIp                  String?
  uploaderUserAgent           String?
  // Exact-match hash. PDQ catches near-duplicates (rotation/recompression);
  // SHA-256 is what NCMEC and other ESPs use for cross-provider exact matches.
  sha256                      String?
  // Intended target context — captured at auto-flag time from the upload
  // request's source/sourceId query params (which channel/DM/avatar slot the
  // user was attempting to attach to). Useful for NCMEC routing decisions
  // and pattern recognition across reports. Null on user-reported content
  // because we already have channelId/dmChannelId on those rows.
  intendedSource              String?
  intendedSourceId            String?
  // 'upload-block'              — captured synchronously at the upload
  //                               request; uploaderIp/UA are the offending
  //                               IP/UA. Highest evidentiary quality.
  // 'action-time-lookup'        — populated when admin transitions a
  //                               user-reported CSAM to actioned; lookup
  //                               found a session active around the
  //                               message's timestamp, snapshot took.
  // 'action-time-unavailable'   — same trigger, but the 90-day Session
  //                               retention window had expired or no
  //                               matching session existed. uploaderIp/UA
  //                               will be null. Surface this in admin UI
  //                               so moderators know they're filing with
  //                               degraded evidence rather than assuming
  //                               IP/UA were captured.
  evidenceSource              String?
  evidenceCapturedAt          DateTime?
  // Set when CSAM evidence preservation begins. Distinct from createdAt
  // because we want a single "evidence preserved since" timestamp regardless
  // of whether the row originated as auto-flag or as a user report.
  preservedAt                 DateTime?
  content                     String // decrypted content at time of report (for E2E DMs)
  attachmentUrl               String?
  reason                      String // "spam" | "harassment" | "csam" | "violence" | "other"
  details                     String? // optional description from reporter
  status                      String    @default("pending") // pending | reviewed | actioned | dismissed
  reviewedAt                  DateTime?
  reviewedBy                  String? // admin user ID
  reviewNotes                 String?
  actionTaken                 String? // "none" | "warn" | "delete" | "ban" | "ncmec_report"
  ncmecReportId               String?
  contentSource               String    @default("server") // "server" | "reporter_disclosed" | "unavailable"
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt
  reporter                    User?     @relation("MessageReportReporter", fields: [reporterId], references: [id], onDelete: SetNull)
  author                      User?     @relation("MessageReportAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([reporterId])
  @@index([authorId])
  @@index([createdAt])
  @@index([reason, preservedAt])
  @@index([messageType, status])
  @@index([status, createdAt])
}

// Server-level abuse report (Community/Public Servers).
// Lets a member flag an entire server (spam, harassment hub, illegal content,
// undeclared NSFW, impersonation). Reporter identity is preserved across
// reporter self-delete via SetNull so the moderator audit trail survives.
// Distinct from MessageReport (per-message); both feed admin T&S queues.
model ServerReport {
  id          String    @id @default(uuid())
  serverId    String
  // Nullable so the report survives reporter self-delete — same invariant as
  // MessageReport.reporterId. T&S queue must outlive the reporter.
  reporterId  String?
  reason      String // "spam" | "harassment" | "illegal" | "nsfw_undeclared" | "impersonation" | "other"
  details     String? // optional reporter-supplied context, ≤2000 chars
  status      String    @default("pending") // pending | reviewed | actioned | dismissed
  actionTaken String? // "none" | "warn" | "hide" | "suspend" | "remove"
  reviewerId  String?
  reviewedAt  DateTime?
  reviewNote  String?
  createdAt   DateTime  @default(now())
  server      Server    @relation(fields: [serverId], references: [id], onDelete: Cascade)
  reporter    User?     @relation("ServerReporter", fields: [reporterId], references: [id], onDelete: SetNull)
  reviewer    User?     @relation("ServerReportReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

  @@index([serverId, status])
  @@index([status, createdAt])
  @@index([reporterId])
}

