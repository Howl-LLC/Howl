model DmKeyBundle {
  id                     String    @id @default(uuid())
  userId                 String    @unique
  publicKey              String // base64 X25519 public key
  // Sibling Ed25519 public key used to sign pending deliveries + participate in
  // safety-number verification. Nullable only for legacy rows; clients lazily
  // generate + upload one on next unlock.
  signingPublicKey       String?
  encryptedBlob          String // AES-256-GCM ciphertext of {privateKey, privateSigningKey, archiveKey}
  blobSalt               String // base64 Argon2id salt
  blobVersion            Int       @default(1)
  recoveryBlob           String // ciphertext under recovery key
  recoveryNonce          String // nonce for recovery blob
  recoveryMode           String?
  recoveryPassphraseSalt String?
  lastRecoveryReminder   DateTime?
  passwordDerived        Boolean   @default(false)
  serverEscrowBlob       String? // AES-256-GCM(HKDF(masterKey, userId), rawBlobContents)
  // Server-side high-water mark for the move-to-Private archiveKey rotation. A
  // history-archive POST whose keyVersion is below this floor is skipped, so a
  // stale sibling tab cannot re-upload rows sealed under the old escrow-exposed
  // archiveKey after the bulk DELETE bumps the floor.
  minArchiveKeyVersion   Int       @default(1)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("SecureKeyBundle")
}

