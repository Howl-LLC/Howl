model ImageHash {
  id         String   @id @default(uuid())
  // PDQ 256-bit hex string. Nullable because non-image uploads (video,
  // audio, PDF, zip) don't have a perceptual hash but still get a row so
  // their SHA-256 is recorded for cross-provider exact-match in NCMEC
  // reports. PDQ-matching code paths must filter `hash: { not: null }`.
  hash       String?
  // SHA-256 of the raw upload bytes, hex. Captured for every non-encrypted
  // upload regardless of media type. PDQ matches near-duplicates of images;
  // SHA-256 is the cross-provider exact-match used by NCMEC and other ESPs
  // for any media type they share hash lists for.
  sha256     String?
  uploaderId String
  filename   String
  source     String // "channel" | "dm" | "avatar" | "banner"
  sourceId   String? // channelId or dmChannelId
  flagMatch  Boolean  @default(false)
  // True when this upload was an encrypted (E2E DM) blob that skipped
  // server-side content safety (MIME/EXIF/decompression-bomb/NCMEC/PDQ).
  // The channel-message send path refuses to attach such a blob to a plaintext,
  // multi-recipient server channel (see routes/messages.ts). Encrypted uploads
  // get a provenance-only row (hash + sha256 null) so this flag is queryable.
  encrypted  Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([hash])
  @@index([sha256])
  @@index([uploaderId])
  // Per-send provenance lookup by stored filename (channel attach-time check).
  @@index([filename])
  @@index([flagMatch])
  @@index([createdAt])
}

model FlaggedHash {
  id        String   @id @default(uuid())
  hash      String   @unique
  reason    String // "csam" | "illegal" | "other"
  source    String   @default("manual") // "manual" | "thorn" | "ncmec"
  addedById String?
  notes     String?
  createdAt DateTime @default(now())

  // Hashes ingested as part of an external corpus (NCMEC / Thorn / IWF) belong
  // to a FlaggedHashSnapshot and are only active when their snapshot is.
  // Manually-added hashes have snapshotId=null and are always active.
  snapshotId String?
  snapshot   FlaggedHashSnapshot? @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([reason])
  @@index([snapshotId])
}

// Versioned hash-list snapshots — one per ingestion. We never edit a snapshot
// after it's built; instead an admin appends hashes during the staging phase,
// then atomically activates it. The previously-active snapshot is deactivated
// in the same transaction so there is exactly one active external snapshot
// at any point. This is the rollback boundary: a corrupt ingestion is
// abandoned by aborting (delete) before activate, or by activating an older
// snapshot if the bad data made it live. Manual FlaggedHash entries are
// orthogonal — they have null snapshotId and stay active independent of
// which corpus is loaded.
model FlaggedHashSnapshot {
  id          String        @id @default(uuid())
  // Monotonic version starting at 1. Used for ordering and human reference
  // ("snapshot v17 from NCMEC, ingested 2026-04-30").
  version     Int           @unique @default(autoincrement())
  source      String // "ncmec" | "thorn" | "iwf" | "internal"
  label       String? // human-readable, e.g. "NCMEC weekly 2026-04-26"
  isActive    Boolean       @default(false)
  hashCount   Int           @default(0)
  createdById String? // admin id; null if ingested by automated job
  createdAt   DateTime      @default(now())
  activatedAt DateTime?
  abortedAt   DateTime? // set if admin aborts staging without activating
  notes       String?
  hashes      FlaggedHash[]

  @@index([isActive])
  @@index([source, createdAt])
}

