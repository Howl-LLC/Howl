  attachmentContentType String?
  attachmentWidth       Int?
  attachmentHeight      Int?
  createdAt             DateTime               @default(now())
  editedAt              DateTime?
  forumPost             ForumPost              @relation(fields: [forumPostId], references: [id], onDelete: Cascade)
  // Forum replies die with their author.
  author                User                   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  reactions             ForumMessageReaction[]

  @@index([forumPostId])
  @@index([forumPostId, createdAt])
  @@index([authorId])
  @@index([attachmentUrl(ops: raw("text_pattern_ops"))])
}

model ForumMessageReaction {
  id        String       @id @default(uuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime     @default(now())
  message   ForumMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

model ForumTag {
  id        String         @id @default(uuid())
  channelId String
  name      String
  emoji     String?
  color     String         @default("#6366f1")
  position  Int            @default(0)
  createdAt DateTime       @default(now())
  channel   Channel        @relation(fields: [channelId], references: [id], onDelete: Cascade)
  posts     ForumPostTag[]

  @@index([channelId])
  @@index([channelId, position])
}

model ForumPostTag {
  postId String
  tagId  String
  post   ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    ForumTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([tagId])
}

model GameAccount {
  id          String          @id @default(uuid())
  userId      String
  game        String // 'cs2' | 'dota2' | 'valorant' | 'lol' | 'tft' | 'fortnite' | 'apex' | 'marvel_rivals' | 'r6_siege'
  provider    String // 'steam' | 'riot' | 'epic' | 'ea' | 'ubisoft' | 'marvel_rivals'
  platformId  String // Steam ID, Riot PUUID, Epic Account ID, or username for non-OAuth providers
  platform    String? // 'pc' | 'psn' | 'xbox' | null
  displayName String? // Gamertag / display name
  verified    Boolean         @default(false) // true = linked via OAuth, false = username entry
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  statsCache  GameStatsCache?

  @@unique([userId, game]) // One account per game per user
  @@index([userId])
  @@index([provider])
}

model GameStatsCache {
  id              String      @id @default(uuid())
  gameAccountId   String      @unique
  gameAccount     GameAccount @relation(fields: [gameAccountId], references: [id], onDelete: Cascade)
  rank            Json? // { tier: string, division: string | null, rating: number | null, imageUrl: string | null }
  stats           Json? // { kd: number, winRate: number, matches: number, ... } — shape varies per game
  lastFetched     DateTime?
  nextRefreshAt   DateTime?
  fetchError      String? // Last error message if fetch failed
  errorRetryCount Int         @default(0)
  errorTransient  Boolean     @default(false) // True when last error is provider-side outage (5xx/429, DB unavailable, rate-limit) — triggers longer cooldown
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model ServerFolder {
  id        String   @id @default(uuid())
  userId    String
  name      String   @db.VarChar(32)
  color     String?  @db.VarChar(7)
  serverIds String[]
  position  Int      @default(0)
  muted     Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AnalyticsSnapshot {
  id          String   @id @default(uuid())
  timestamp   DateTime @default(now())
  region      String // NA, EU, ASIA, SA, OCE, AF
  onlineCount Int

  @@index([timestamp])
  @@index([region, timestamp])
}

model ProtocolDistributionSnapshot {
  id              String   @id @default(uuid())
  timestamp       DateTime @default(now())
  buildDate       String? // ISO "YYYY-MM-DD" or null for pre-versioning clients
  platform        String // "electron" | "web" | "unknown"
  protocolVersion Int? // null when client didn't send the field
  count           Int

  @@index([timestamp])
  @@index([buildDate])
}

// Per-user security event audit log. Records user-initiated
// state changes that matter during account-compromise investigations
// (password change, email change, MFA enroll/disable, passkey add/remove,
// session revoke, logout-all, self-delete). Written fire-and-forget by
// routes/services/securityEvents.ts emitUserSecurityEvent helper; exposed
// read-only at GET /api/v1/me/security-events so the account owner can
// review their own activity without waiting on admin support.
//
// eventType values are a closed set defined in services/securityEvents.ts
// (UserSecurityEventType). metadata must never contain secrets —
// passwords, tokens, MFA codes, recovery codes, or plaintext emails.
// For email change: { newEmailHash: <hmac> }. For session revoke:
// { sessionId }. For SSO login: { provider }.
//
// Cascade-deletes with the owning user (GDPR self-delete). Rely on
// structured `logger.info` emission inside the helper for any tracing
// that must outlive the user row; the table is for in-app account
// review, not forensic retention.
model UserSecurityEvent {
  id            String   @id @default(uuid())
  userId        String
  eventType     String // password_changed | email_change_requested | email_change_confirmed | mfa_totp_enabled | mfa_totp_disabled | mfa_recovery_regen | passkey_added | passkey_removed | session_revoked | logout_all | self_delete_initiated | login_success | login_new_device
  ipMasked      String?
  userAgentHash String?
  metadata      Json?
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}

// Per-server per-day insight rollups (public/community-servers).
//
// Computed by the BullMQ `serverStats` worker at 00:30 UTC for the previous
// UTC day. One row per (serverId, date). Read by the owner-facing
// `GET /api/v1/servers/:serverId/insights` endpoint.
//
// CRITICAL: aggregations cover Server / ServerMember / Channel / Message
// only. DM / DMMessage are E2E encrypted and explicitly excluded — the
// server only sees opaque ciphertext. See docs/howl-dm-encryption-spec.md.
//
// `voiceMinutes` is best-effort. Howl has `StageSession` (with `endedAt`)
// but no per-user voice tracking. The worker aggregates stage-session
// minutes for the date window; LiveKit-managed voice-channel sessions
// aren't persisted to Postgres so they contribute 0 here.
//
// `leaves` is best-effort. ServerMember rows are deleted on leave/kick/ban
// (no `leftAt` column). The worker leaves this at 0 for future expansion;
// ban/kick can be inferred from AuditLog by a future migration if needed.
model DailyServerStats {
  id              String   @id @default(uuid())
  serverId        String
  date            DateTime @db.Date
  members         Int      @default(0)
  joins           Int      @default(0)
  leaves          Int      @default(0)
  messages        Int      @default(0)
  voiceMinutes    Int      @default(0)
  retainedAfter7d Int      @default(0)
  computedAt      DateTime @default(now())

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([serverId, date])
  @@index([serverId, date])
}

// Self Roles — picker channel + categories + entries + manual-approval queue.
// One picker per server (v1) — enforced by `@unique` on serverId. Each picker
// is a Channel of type='role_picker'. Cascade everywhere from the picker root
// down. Roles are linked but not owned — cascading on role delete cleans up
// just the entry, not the role itself.

model RolePickerChannel {
  id              String   @id @default(uuid())
  channelId       String   @unique
  // One picker per server. Schema-enforced. Backend channel-create rejects
  // with 409 when this constraint would be violated; defense in depth.
  serverId        String   @unique
  heroTitle       String?  @db.VarChar(80)
  heroDescription String?  @db.VarChar(280)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  channel    Channel              @relation(fields: [channelId], references: [id], onDelete: Cascade)
  server     Server               @relation(fields: [serverId], references: [id], onDelete: Cascade)
  categories RolePickerCategory[]
}

model RolePickerCategory {
  id        String   @id @default(uuid())
  pickerId  String
  name      String   @db.VarChar(40)
  position  Int
  pickMode  String   @default("multi") // 'single' | 'multi'
  required  Boolean  @default(false)
  createdAt DateTime @default(now())

  picker  RolePickerChannel @relation(fields: [pickerId], references: [id], onDelete: Cascade)
  entries RolePickerEntry[]

  @@unique([pickerId, position])
  @@index([pickerId])
}

model RolePickerEntry {
  id           String   @id @default(uuid())
  categoryId   String
  roleId       String
  position     Int
  emoji        String?  @db.VarChar(8)
  /// Custom icon for the role tile. Pro-tier feature — set via the upload
  /// flow on the admin picker UI. When non-null this takes precedence over
  /// `emoji` at render time. URL must point at our own upload host (R2/CDN);
  /// the route layer rejects external URLs and non-Pro accounts.
  iconUrl      String?  @db.VarChar(2048)
  description  String?  @db.VarChar(200)
  /// JSON blob — see ConditionRequirements in conditionEvaluator.ts.
  /// Schema-flexible so new condition types can be added without migration.
  requirements Json?
  createdAt    DateTime @default(now())

  category RolePickerCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  role     ServerRole         @relation(fields: [roleId], references: [id], onDelete: Cascade)
  requests RoleClaimRequest[]

  @@unique([categoryId, roleId])
  @@index([categoryId])
  @@index([roleId])
}

model RoleClaimRequest {
  id               String    @id @default(uuid())
  serverId         String
  userId           String
  pickerEntryId    String
  // Cached for queue display even if the entry is later removed.
  roleId           String
  status           String    @default("pending") // 'pending' | 'approved' | 'rejected' | 'withdrawn'
  applicantMessage String?   @db.VarChar(500)
  decidedById      String?
  decisionNote     String?   @db.VarChar(500)
  createdAt        DateTime  @default(now())
  decidedAt        DateTime?

  server    Server          @relation(fields: [serverId], references: [id], onDelete: Cascade)
  user      User            @relation("RoleClaimRequestApplicant", fields: [userId], references: [id], onDelete: Cascade)
  decidedBy User?           @relation("RoleClaimRequestDecider", fields: [decidedById], references: [id], onDelete: SetNull)
  entry     RolePickerEntry @relation(fields: [pickerEntryId], references: [id], onDelete: Cascade)
  // Partial unique (status='pending') is added in raw SQL in the migration —
  // Prisma can't express it as @@unique here.

  @@index([serverId, status, createdAt])
  @@index([userId])
}

model MlsGroup {
  id             String   @id @default(uuid())
  dmChannelId    String
  tier           String   @default("saved") // 'saved' | 'otr'
  cipherSuite    Int      @default(83) // keep in sync with MLS_CIPHERSUITE_ID (src/mls/ciphersuite.ts)
  currentEpoch   BigInt   @default(0) // the CAS target
  groupInfo      Bytes? // latest published GroupInfo (public, incl. public ratchet tree); set inside the CAS UPDATE
  groupInfoEpoch BigInt?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  dmChannel      DMChannel   @relation(fields: [dmChannelId], references: [id], onDelete: Cascade)
  commits        MlsCommit[]

  @@unique([dmChannelId, tier]) // one group per (channel, tier); create-once guard
}

model MlsCommit {
  id             String   @id @default(uuid())
  groupId        String
  epoch          BigInt // the CONSUMED base epoch N (this commit advanced N -> N+1)
  commitData     Bytes // accepted MLSMessage (public handshake), relayed verbatim
  idempotencyKey String // client nonce or hash of the serialized message
  senderLeaf     String? // sender leaf ref/index, for authz/audit
  createdAt      DateTime @default(now())
  group          MlsGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, epoch]) // durable double-accept backstop
  @@unique([groupId, idempotencyKey]) // resubmission idempotency
}

model MlsKeyPackage {
  id            String    @id @default(uuid())
  userId        String
  deviceId      String
  keyPackageRef String    @unique // makeKeyPackageRef hash (base64); consume dedupe key
  keyPackage    Bytes // public KeyPackage (no private material)
  isLastResort  Boolean   @default(false)
  notAfter      DateTime // real lifetime; DS prunes/refuses expired
  consumedAt    DateTime? // tombstone (null = available)
  createdAt     DateTime  @default(now())
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, deviceId, consumedAt])
  @@index([notAfter])
}

model MlsWelcome {
  id          String   @id @default(uuid())
  recipientId String
  groupId     String
  epoch       BigInt
  welcomeData Bytes // MLS Welcome (sealed to joiner init key), opaque to server
  createdAt   DateTime @default(now())
  recipient   User     @relation("MlsWelcomeRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@unique([recipientId, groupId, epoch]) // single-use per (group, joiner, epoch)
  @@index([recipientId])
}

// One predecessor-signed AIK rotation hop oldAik -> newAik at a 1-based per-user seq.
// The server stores these OPAQUELY and does zero crypto: the signature is verified only
// client-side, rooted at the verifier's own pinned AIK (see services/mls/aikRotation).
// The three @@unique constraints are HONEST-SERVER defense-in-depth (the client enforces
// linearity); `context` is display-only — the verifier uses a compiled-in label.
model AikRotation {
  id        String   @id @default(uuid())
  userId    String
  seq       Int
  oldAik    String // base64 Ed25519 public key (predecessor)
  newAik    String // base64 Ed25519 public key (successor)
  signature String // base64 Ed25519 detached signature over the link message, under oldAik
  context   String // "howl:mls:aik-rotation:v1" — DISPLAY ONLY
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, seq]) // no duplicate sequence numbers
  @@unique([userId, oldAik]) // single out-degree per key (no fork)
  @@unique([userId, newAik]) // single in-degree per key (no merge)
  @@index([userId])
}

// The current signed head per user: the anti-rollback freshness anchor at the chain tip.
model AikHead {
  userId    String   @id
  seq       Int
  aik       String // base64 Ed25519 public key (current head == chain tip's newAik)
  signature String // base64 Ed25519 detached signature over the head message, under aik
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DmHistoryArchive {
  id           String   @id @default(uuid())
  userId       String
  dmChannelId  String
  envelopeHash String // hex SHA-256 of the source envelope; dedup key (<=128)
  ciphertext   String // base64(iv || AES-256-GCM(archiveKey, plaintext, AAD)); opaque to server
  keyVersion   Int      @default(1) // which archiveKey generation sealed this row
  messageId    String // DMMessage id; delete-for-everyone + GDPR targeting
  msgCreatedAt DateTime // client archive time; oldest-first restore + latest-per-channel preview
  createdAt    DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  dmChannel DMChannel @relation(fields: [dmChannelId], references: [id], onDelete: Cascade)

  @@unique([userId, dmChannelId, envelopeHash]) // idempotent upsert; multi-device convergence
  @@index([userId, dmChannelId, msgCreatedAt]) // previews + paginated full restore
  @@index([userId, dmChannelId, messageId]) // delete-for-everyone
  @@index([userId]) // bulk delete (move-to-Private, GDPR, reset)
  @@index([userId, msgCreatedAt, id]) // global per-user oldest-first eviction scan
}

// Write-once record that a messageId was deleted-for-everyone.
// Per-user (the archive itself is per-user); the DELETE handler writes it in the
// same tx as the row deletion, and POST filters tombstoned items so a deleted
// message can never be re-uploaded (re-POST resurrection race) or restored.
model DmHistoryArchiveTombstone {
  id          String   @id @default(uuid())
  userId      String
  dmChannelId String
  messageId   String
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  dmChannel DMChannel @relation(fields: [dmChannelId], references: [id], onDelete: Cascade)

  @@unique([userId, dmChannelId, messageId]) // write-once (ON CONFLICT DO NOTHING)
  @@index([userId, dmChannelId])
}
