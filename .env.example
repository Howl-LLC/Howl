# Root .env — used by Vite (frontend) when you run from project root. Do NOT put backend vars here.

# Optional: Backend port the browser uses for API/WebSocket. Default 5000.
# VITE_BACKEND_PORT=5000

# Optional: Full backend URL. Overrides host+port detection.
# For local dev this is usually not needed (Vite proxy handles it).
# VITE_BACKEND_URL=https://api.example.com

# Optional: Use same origin for API/WS (both served from one domain).
# VITE_SAME_ORIGIN=true

# --- Production build: set before npm run build:frontend ---
# VITE_BACKEND_URL=https://api.example.com
#
# ── Local dev ───────────────────────────────────────────────────────────
#
#   The Vite proxy handles /api and /socket.io in local dev, so you don't
#   need to set VITE_BACKEND_URL or run any tunnels.
#
#   To share a running instance with remote users, expose ports 3000
#   (frontend), 5000 (backend), and 7880 (LiveKit) over any HTTPS tunnel,
#   then point VITE_BACKEND_URL / FRONTEND_ORIGIN / LIVEKIT_WS_URL at the
#   resulting URLs (use wss:// for LIVEKIT_WS_URL) and restart the backend.
#
# ── Production ──────────────────────────────────────────────────────────
#
#   In production there are NO tunnels. Everything has a stable domain:
#     - Frontend:  https://app.example.com
#     - Backend:   https://api.example.com
#     - LiveKit:   wss://livekit.example.com
#   Set VITE_BACKEND_URL above and the backend env vars once; they never change.

# --- Home page ads (Google AdSense). If unset, placeholders show; no ad script is loaded. ---
# VITE_ADSENSE_CLIENT_ID=ca-pub-xxxxxxxxxxxxxxxx
# VITE_ADSENSE_SLOT_HEADER=xxxxxxxxxx
# VITE_ADSENSE_SLOT_SIDEBAR=xxxxxxxxxx

# --- Klipy GIF API — DEPRECATED. GIF search is now proxied through the backend. ---
# Set KLIPY_API_KEY in backend/.env instead. Do NOT set VITE_KLIPY_API_KEY.
# VITE_KLIPY_API_KEY=

# --- CAPTCHA (Cloudflare Turnstile). Leave empty in dev to skip. ---
# VITE_TURNSTILE_SITE_KEY=

# --- Desktop app downloads. Base URL where Howl-Setup.exe / Howl.dmg / Howl.AppImage are hosted.
# Defaults to GitHub Releases latest. Set to your own CDN/object-storage URL if hosting elsewhere.
# VITE_DOWNLOAD_BASE_URL=https://github.com/HowlPro/Howl/releases/latest/download

# --- Error tracking (Sentry). Leave empty in dev to disable. ---
# Get DSN from https://sentry.io → Project Settings → Client Keys (DSN).
# VITE_SENTRY_DSN=
# VITE_APP_VERSION=1.0.0

# --- Homepage "Support Us" donate button. ---
# Static URL to a Stripe-hosted donation page (create one in your Stripe
# Dashboard → Payment Links or Donations). When unset, the Donate-via-Stripe
# button inside the Support Us modal is hidden entirely — set this env var
# and rebuild the frontend to enable it.
# VITE_DONATE_URL=https://donate.stripe.com/your-donation-page-id
