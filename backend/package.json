{
  "name": "howl-backend",
  "version": "1.0.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "npx tsx src/server.ts",
    "dev:backend": "npx tsx src/server.ts",
    "build": "tsc",
    "start": "node dist/src/start.js",
    "start:worker": "node dist/src/worker.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "prisma db seed",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:auth": "vitest run tests/auth.test.ts",
    "test:messages": "vitest run tests/messages.test.ts",
    "test:servers": "vitest run tests/servers.test.ts",
    "test:uploads": "vitest run tests/upload.test.ts",
    "test:db": "vitest run tests/db.test.ts",
    "create-admin": "npx tsx src/scripts/createAdmin.ts",
    "reset-admin-password": "npx tsx src/scripts/resetAdminPassword.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "audit:security": "npm audit --production --audit-level=high",
    "security": "npm run lint && npm run audit:security && npx tsc --noEmit"
  },
  "dependencies": {
