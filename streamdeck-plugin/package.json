{
  "name": "@howl/streamdeck-plugin",
  "version": "1.0.3",
  "private": true,
  "type": "module",
  "description": "Elgato Stream Deck plugin for Howl — voice, calls, reactions, and more.",
  "scripts": {
    "icons": "node scripts/generate-icons.mjs",
    "sync-version": "node scripts/sync-version.mjs",
    "prebuild": "npm run sync-version && npm run icons",
    "build": "node esbuild.config.js",
    "dev": "node esbuild.config.js --watch",
    "typecheck": "tsc --noEmit",
    "validate": "streamdeck validate com.howlpro.streamdeck.sdPlugin",
    "validate:local": "node scripts/validate.js",
    "package": "streamdeck pack com.howlpro.streamdeck.sdPlugin --force",
    "package:local": "node scripts/package.js"
  },
  "dependencies": {
    "@elgato/streamdeck": "^2.1.0",
    "@napi-rs/canvas": "^0.1.65",
    "ws": "^8.19.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@elgato/cli": "^1.7.4",
    "@types/ws": "^8.5.14",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  }
}
