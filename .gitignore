# Large binaries
*.exe
tools/nuclei*

# MediaPipe WASM — copied from node_modules on postinstall (see scripts/copy-mediapipe-assets.mjs)
# .tflite model files under public/mediapipe/models/ ARE committed (~500 KB).
public/mediapipe/wasm/
# RNNoise sync bundle (~1.9 MB) — copied from @jitsi/rnnoise-wasm on postinstall.
public/rnnoise-sync.js

# Fontshare display fonts (Clash Display + Satoshi) — fetched at build via
# scripts/fetch-fonts.mjs; not committed (ITF Free Font License redistribution).
public/fonts/clash-display/
public/fonts/satoshi/

# Certificates / keys
*.pem
*.key
*.cert

