# Howl self-host configuration. Copy to .env (or run ./setup.sh to generate one).
# Keep .env secret. Do NOT reuse secrets across instances.

# --- Core self-host mode ---
SELF_HOST=true
SELF_HOST_ALL_PRO=true
REGISTRATION_MODE=closed          # open = anyone can sign up; closed = admin provisions users
INSTANCE_NAME=Howl
DOMAIN=chat.example.com           # the public hostname Caddy gets a cert for

# --- Database / cache (compose-internal) ---
POSTGRES_PASSWORD=change-me
REDIS_PASSWORD=change-me           # openssl rand -hex 24

# --- App secrets (generate with: openssl rand -hex N) ---
JWT_SECRET=                       # openssl rand -hex 48
ADMIN_JWT_SECRET=                 # openssl rand -hex 48 (MUST differ from JWT_SECRET)
EMAIL_HMAC_KEY=                   # openssl rand -hex 32
MFA_ENCRYPTION_KEY=               # openssl rand -hex 32 (exactly 64 hex chars)
DM_ENCRYPTION_KEY=                # openssl rand -hex 32 (exactly 64 hex chars)
SERVER_E2E_MASTER_KEY=            # openssl rand -hex 32 (enables opt-in "Server recovery" E2E mode)
BOOTSTRAP_TOKEN=                  # openssl rand -hex 24 (one-time token to create the first admin)

# Cloudflare Access is not used on self-host
CF_ACCESS_ENFORCE=false

# --- Voice: bring-your-own LiveKit (leave blank to run text-only) ---
# LIVEKIT_WS_URL=wss://your-livekit-host
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=

# --- Email (optional; set to enable verification + password-reset emails) ---
# RESEND_API_KEY=
